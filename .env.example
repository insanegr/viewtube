# ============================================
# ViewTube — stack.env for Portainer
# ============================================
# In Portainer: Stack > Environment variables > Load from file
# Or paste these into the "Advanced" env editor
# ============================================

# Secret keys — CHANGE THESE!
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_PASTE_RANDOM_HEX_HERE
JWT_REFRESH_SECRET=CHANGE_ME_PASTE_ANOTHER_RANDOM_HEX_HERE

# Admin account (only used on FIRST RUN when database is empty)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=Admin

# Import root inside container
# With the recommended compose file, this is /videos-root and maps to host /mnt
IMPORT_DIR=/videos-root
